+
+enum CellOutcome {
+    Completed {
+        content: Vec<ToolOutputContent>,
+        stored: HashMap<String, Value>,
+        nested_calls: Vec<NestedToolCall>,
+    },
+    ScriptFailed {
+        message: String,
+        stored: HashMap<String, Value>,
