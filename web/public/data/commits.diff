+  }
+
+  .terminal-branch {
+    border-right: 0;
+    border-bottom: 1px solid var(--border);
+  }
+
+  .architecture-invariants {
+    grid-template-columns: 1fr;
+  }
+}
+
+@media (max-width: 880px) {
