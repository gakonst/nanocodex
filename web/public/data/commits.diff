+fn strip_item_id(mut item: Value) -> Value {
+    if let Some(object) = item.as_object_mut() {
+        object.remove("id");
+    }
+    item
+}
+
+const fn status(success: bool) -> &'static str {
+    if success { "completed" } else { "failed" }
