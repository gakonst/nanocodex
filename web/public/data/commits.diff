+/* Compact rail-and-viewer workspaces, shared by Code and Commits. */
+.site-shell {
+  display: flex;
+  flex-direction: column;
+}
+
+.site-header {
+  position: relative;
+  flex: 0 0 var(--header-height);
+  padding-inline: 16px;
+  backdrop-filter: none;
+}
+
+.surface-code,
+.surface-commits {
+  height: 100dvh;
+  min-height: 0;
+  overflow: hidden;
+}
+
+.surface-code > main,
+.surface-commits > main {
+  flex: 1 1 auto;
+  min-height: 0;
+  overflow: hidden;
+}
+
+.code-workspace,
+.commits-workspace {
+  position: relative;
+  display: grid;
+  grid-template-columns: 320px minmax(0, 1fr);
+  width: 100%;
+  height: 100%;
+  min-height: 0;
+  overflow: hidden;
+}
+
+.code-tree-panel,
+.commit-sidebar {
+  min-width: 0;
+  min-height: 0;
+  overflow: hidden;
+  background: var(--surface-subtle);
+  border: 0;
+  border-right: 1px solid var(--border-soft);
+  border-radius: 0;
+}
+
+.code-tree-panel {
+  position: relative;
+  top: auto;
+}
+
+.pierre-file-tree {
+  display: block;
+  width: 100%;
+  height: 100%;
