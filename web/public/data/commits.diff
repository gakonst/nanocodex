+}
+
+.cv-scrollbar::-webkit-scrollbar {
+  width: 12px;
+  height: 12px;
+}
+
+.cv-scrollbar::-webkit-scrollbar-track {
+  margin-top: -1px;
+  background: var(--surface-subtle);
+  border-left: 1px solid var(--border-soft);
+}
+
+.cv-scrollbar::-webkit-scrollbar-thumb {
+  background-color: var(--cv-scrollbar-thumb-bg);
+  background-clip: content-box;
+  border: 2px solid transparent;
+  border-radius: 6px;
+}
+
+@supports (-moz-appearance: none) {
+  .cv-scrollbar {
+    scrollbar-color: var(--cv-scrollbar-thumb-bg) var(--surface-subtle);
+  }
+}
+
+.code-view diffs-container {
+  overflow: clip;
+  contain: layout paint style;
+  box-shadow:
+    0 -1px 0 var(--border-soft),
+    0 1px 0 var(--border-soft);
+}
+
+.commit-stream {
+  width: 100%;
+  height: 100%;
+  flex: 1 1 auto;
+  background: var(--surface-subtle);
+}
+
+.commit-section-header {
+  display: flex;
+  flex-direction: column;
+  justify-content: center;
+  gap: 1px;
+  min-width: 0;
+  height: 44px;
+  padding: 3px 28px;
+  overflow: hidden;
+  color: var(--text);
+  background: var(--surface);
+}
+
+.commit-section-header h2 {
+  min-width: 0;
+  overflow: hidden;
+  font-size: 23px;
+  line-height: 25px;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.commit-code-metadata {
+  display: flex;
+  gap: 12px;
+  align-items: center;
+  min-width: 0;
+  width: 100%;
+  color: var(--text-muted);
+  font-size: 9px;
+  font-weight: 400;
+  line-height: 12px;
+  white-space: nowrap;
+}
+
+.commit-file-header {
+  display: flex;
+  gap: 10px;
+  align-items: center;
+  width: 100%;
+  height: 44px;
+  min-width: 0;
+  padding: 0 16px;
+  color: var(--text);
+  background: var(--surface);
+}
+
+.commit-file-status {
+  width: 14px;
+  height: 14px;
+  flex: 0 0 14px;
+  border: 2px solid var(--blue);
+  border-radius: 5px;
+}
+
+.commit-file-status.is-new {
+  border-color: var(--positive);
+}
+
+.commit-file-status.is-deleted {
+  border-color: var(--negative);
+  border-radius: 50%;
+}
+
+.commit-file-path {
+  min-width: 0;
+  overflow: hidden;
+  font-size: 11px;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.commit-file-stats {
+  display: flex;
+  gap: 8px;
+  align-items: center;
+  margin-left: auto;
+  font-size: 10px;
+  white-space: nowrap;
+}
+
+.commit-file-stats .additions {
+  color: var(--positive);
+}
+
+.commit-file-stats .deletions {
+  color: var(--negative);
+}
+
+.commit-section-hash,
+.commit-code-metadata .additions,
+.commit-code-metadata .deletions {
+  font-family: "Paradigm SemiMono", SFMono-Regular, Menlo, Monaco, Consolas, monospace;
+}
+
+.commit-section-hash {
+  color: var(--text);
+  letter-spacing: 0.02em;
+  text-transform: uppercase;
+}
+
+.commit-code-metadata .additions {
+  color: var(--positive);
+}
+
+.commit-code-metadata .deletions {
+  color: var(--negative);
+}
+
+@media (max-width: 740px) {
+  .surface-code .header-actions,
+  .surface-commits .header-actions {
+    display: none;
+  }
+
+  .surface-code .site-header,
+  .surface-commits .site-header {
+    grid-template-columns: minmax(0, 1fr);
+  }
+
+  .code-workspace,
+  .commits-workspace {
+    display: block;
+  }
+
+  .code-tree-panel,
+  .commit-sidebar {
+    position: absolute;
+    z-index: 22;
+    top: 0;
+    bottom: 0;
+    left: 0;
+    width: min(320px, 88vw);
+    max-height: none;
+    border-right: 1px solid var(--border);
+    border-radius: 0;
+    box-shadow: 18px 0 50px rgba(0, 0, 0, 0.14);
+    visibility: hidden;
+    pointer-events: none;
+    transform: translateX(-105%);
+    transition: transform 160ms ease, visibility 0s linear 160ms;
+  }
+
+  .code-tree-panel.is-mobile-open,
+  .commit-sidebar.is-mobile-open {
+    visibility: visible;
+    pointer-events: auto;
+    transform: translateX(0);
+    transition-delay: 0s;
+  }
+
+  .workspace-backdrop {
+    position: absolute;
+    z-index: 21;
+    inset: 0;
+    width: 100%;
+    height: 100%;
+    padding: 0;
+    background: rgba(0, 0, 0, 0.28);
+    cursor: pointer;
+  }
+
+  .workspace-backdrop.is-visible {
+    display: block;
+  }
+
+  .pierre-tree-heading button {
+    display: grid;
+    width: 36px;
+    height: 36px;
+  }
+
+  .pierre-tree-heading .tree-search-trigger {
+    display: inline-flex;
+  }
+
+  .mobile-tree-toggle {
+    display: grid;
+    flex: 0 0 auto;
+    width: 36px;
+    height: 36px;
+    padding: 0;
+    background: var(--surface-subtle);
+    border-radius: var(--radius-small);
+    cursor: pointer;
+    place-items: center;
+  }
+
+  .mobile-tree-toggle svg {
+    width: 13px;
+    height: 13px;
+  }
+
+  .code-file,
+  .commit-stream-pane {
+    width: 100%;
+    height: 100%;
+  }
+
+  .code-file-header {
+    gap: 8px;
+    padding-inline: 8px;
+  }
+
+  .commit-sidebar-header .icon-button,
+  .commit-scope-tabs button {
+    min-height: 36px;
+  }
+
+  .mobile-drawer-close {
+    display: grid;
+    width: 36px;
+    height: 36px;
+    padding: 0;
+    background: var(--surface-raised);
+    border-radius: var(--radius-small);
+    cursor: pointer;
+    place-items: center;
+  }
+
+  .mobile-drawer-close svg {
+    width: 13px;
+    height: 13px;
+  }
+
+  .code-file-search span,
+  .code-file-search kbd,
+  .code-file-meta > span:last-child {
+    display: none;
+  }
+
+  .code-file-search {
+    justify-content: center;
+    width: 36px;
+    min-height: 36px;
+    padding: 0;
+  }
+
+  .file-search-result {
+    grid-template-columns: minmax(0, 1fr) 14px;
+  }
+
+  .commit-stream-toolbar {
+    padding-inline: 8px 12px;
+  }
+
+  .commit-code-metadata {
+    gap: 8px;
+  }
+
+  .commit-code-metadata > span:nth-child(2),
+  .commit-code-metadata > span:nth-child(3) {
+    display: none;
+  }
+
+  .commit-section-header {
+    padding-inline: 16px;
+  }
+
+  .commit-section-header h2 {
+    font-size: 21px;
+  }
+
+  .detail-header {
+    min-height: 150px;
+    padding: 12px 14px 16px;
+  }
+
+  .detail-header h2 {
+    margin-top: 16px;
+    font-size: 26px;
+  }
+
+  .detail-byline {
+    margin-top: 38px;
+  }
+
+  .detail-stats {
+    top: auto;
+    right: auto;
+    bottom: 40px;
+    left: 14px;
+  }
+
+  .commit-record {
+    margin-inline: 14px;
+  }
+}
+
+/* Architecture */
+
+.architecture-page {
+  padding-top: 68px;
+  padding-bottom: 112px;
+}
+
+.architecture-hero {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) minmax(390px, 520px);
+  gap: clamp(48px, 7vw, 120px);
+  align-items: end;
+  width: min(100%, 1380px);
+  margin-inline: auto;
+}
+
+.architecture-intro {
+  padding-bottom: 8px;
+}
+
+.architecture-status {
+  width: 6px;
+  height: 6px;
+  background: var(--positive);
+  border-radius: 50%;
+  box-shadow: 0 0 0 3px color-mix(in srgb, var(--positive) 15%, transparent);
+}
+
+.architecture-intro h1 {
+  max-width: 720px;
+  margin-top: 20px;
+  font-size: clamp(44px, 5vw, 72px);
+  line-height: 0.94;
+}
+
+.architecture-intro > p:last-child {
+  max-width: 640px;
+  margin-top: 26px;
+  color: var(--text-muted);
+  font-size: 14px;
+  line-height: 1.65;
+}
+
+.api-contract {
+  overflow: hidden;
+  background: var(--surface-subtle);
+  border: 1px solid var(--border);
+  border-radius: var(--radius-small);
+}
+
+.api-contract > header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  height: 38px;
+  padding: 0 14px;
+  color: var(--text-muted);
+  border-bottom: 1px solid var(--border-soft);
+  font-size: 9px;
+  letter-spacing: 0.04em;
+  text-transform: uppercase;
+}
+
+.api-contract pre {
+  padding: 22px 24px;
+  overflow-x: auto;
+  color: var(--text);
+  background: var(--surface);
+  font-size: 12px;
+  line-height: 1.7;
+}
+
+.api-contract code > span,
+.setup-flow code,
+.runtime-setup code,
+.flow-card strong,
+.branch-flow code,
+.tool-flow-step code {
+  color: var(--blue);
+}
+
+.api-contract dl {
+  display: grid;
+  grid-template-columns: 1fr 1.4fr;
+  gap: 1px;
+  background: var(--border-soft);
+  border-top: 1px solid var(--border-soft);
+}
+
+.api-contract dl > div {
+  padding: 13px 14px 15px;
+  background: var(--surface-subtle);
+}
+
+.api-contract dt {
+  color: var(--text-muted);
+  font-size: 9px;
+  text-transform: uppercase;
+}
+
+.api-contract dd {
+  margin-top: 6px;
+  font-size: 10px;
+  line-height: 1.5;
+}
+
+.architecture-section {
+  width: min(100%, 1500px);
+  margin: 96px auto 0;
+}
+
+.architecture-section-heading {
+  display: grid;
+  grid-template-columns: 1fr minmax(280px, 430px);
+  gap: 40px;
+  align-items: end;
+  margin-bottom: 30px;
+}
+
+.architecture-section-heading h2,
+.architecture-invariants h2 {
+  margin-top: 7px;
+  font-size: 32px;
+  line-height: 1.05;
+}
+
+.architecture-section-heading > p {
+  color: var(--text-muted);
+  line-height: 1.55;
+}
+
+.callgraph {
+  padding: clamp(28px, 4vw, 58px);
+  background:
+    linear-gradient(var(--border-soft) 1px, transparent 1px),
+    linear-gradient(90deg, var(--border-soft) 1px, transparent 1px),
+    var(--surface-subtle);
+  background-size: 24px 24px;
+  border: 1px solid var(--border);
+  border-radius: var(--radius-small);
+}
+
+.flow-card {
+  display: flex;
+  min-height: 112px;
+  flex-direction: column;
+  justify-content: center;
+  padding: 17px 19px;
+  background: var(--surface);
+  border: 1px solid var(--border);
+  border-radius: var(--radius-small);
+}
+
+.flow-card--public {
+  width: min(100%, 360px);
+  min-height: 126px;
+  margin-inline: auto;
+  color: var(--text-inverse);
+  background: var(--text);
+  border-color: var(--text);
+  box-shadow: 0 16px 40px color-mix(in srgb, var(--text) 12%, transparent);
+}
+
+.flow-card--public strong,
+.flow-card--public small,
+.flow-card--public .flow-card-index {
+  color: inherit;
+}
+
+.flow-card-index {
+  margin-bottom: 9px;
+  color: var(--text-muted);
+  font-size: 9px;
+  letter-spacing: 0.06em;
+  text-transform: uppercase;
+}
+
+.flow-card strong {
+  font-size: 13px;
+  font-weight: 500;
+}
+
+.flow-card small {
+  margin-top: 7px;
+  color: var(--text-muted);
+  font-size: 10px;
+  line-height: 1.5;
+}
+
+.flow-arrow {
+  position: relative;
+  display: block;
+  flex: 0 0 auto;
+}
+
+.flow-arrow--down {
+  width: 20px;
+  height: 52px;
+  margin-inline: auto;
+}
+
+.flow-arrow--down::before,
+.flow-arrow--down span {
+  position: absolute;
+  top: 0;
+  bottom: 7px;
+  left: 50%;
+  width: 1px;
+  background: var(--text);
+  content: "";
+}
+
+.flow-arrow--down::after {
+  position: absolute;
+  bottom: 6px;
+  left: 50%;
+  width: 7px;
+  height: 7px;
+  border-right: 1px solid var(--text);
+  border-bottom: 1px solid var(--text);
+  content: "";
+  transform: translateX(-3px) rotate(45deg);
+}
+
+.flow-arrow--right {
+  width: 36px;
+  height: 20px;
+  align-self: center;
+}
+
+.flow-arrow--right::before {
+  position: absolute;
+  top: 50%;
+  right: 6px;
+  left: 0;
+  height: 1px;
+  background: var(--text);
+  content: "";
+}
+
+.flow-arrow--right::after {
+  position: absolute;
+  top: 50%;
+  right: 5px;
+  width: 7px;
+  height: 7px;
+  border-top: 1px solid var(--text);
+  border-right: 1px solid var(--text);
+  content: "";
+  transform: translateY(-3px) rotate(45deg);
+}
+
+.setup-stage,
+.runtime-loop {
+  overflow: hidden;
+  background: var(--surface);
+  border: 1px solid var(--border);
+  border-radius: var(--radius-small);
+}
+
+.setup-stage > header,
+.runtime-loop-heading {
+  display: flex;
+  gap: 13px;
+  align-items: center;
+  min-height: 58px;
+  padding: 10px 16px;
+  border-bottom: 1px solid var(--border-soft);
+}
+
+.setup-stage > header > span,
+.runtime-loop-heading > span:first-child {
+  color: var(--text-muted);
+  font-size: 9px;
+}
+
+.setup-stage > header div,
+.runtime-loop-heading div {
+  display: flex;
+  min-width: 0;
+  flex-direction: column;
+  gap: 3px;
+}
+
+.setup-stage > header strong,
+.runtime-loop-heading strong {
+  font-size: 11px;
+  font-weight: 500;
+}
+
+.setup-stage > header small,
+.runtime-loop-heading small {
+  color: var(--text-muted);
+  font-size: 9px;
+}
+
+.setup-flow {
+  display: grid;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+  margin: 0;
+  padding: 0;
+  list-style: none;
+}
+
+.setup-flow li {
+  position: relative;
+  display: flex;
+  min-height: 126px;
+  flex-direction: column;
+  justify-content: center;
+  padding: 18px 24px 18px 20px;
+}
+
+.setup-flow li + li {
+  border-left: 1px solid var(--border-soft);
+}
+
+.setup-flow li:not(:last-child)::after {
+  position: absolute;
+  z-index: 1;
+  top: 50%;
+  right: -4px;
+  width: 7px;
+  height: 7px;
+  background: var(--surface);
+  border-top: 1px solid var(--border);
+  border-right: 1px solid var(--border);
+  content: "";
+  transform: translateY(-50%) rotate(45deg);
+}
+
+.setup-flow code,
+.runtime-setup code,
+.branch-flow code,
+.tool-flow-step code {
+  font-size: 11px;
+}
+
+.setup-flow li > span {
+  margin-top: 8px;
+  line-height: 1.45;
+}
+
+.setup-flow li > small {
+  margin-top: 13px;
+  color: var(--text-muted);
+  font-size: 9px;
+}
+
+.runtime-loop {
+  border-width: 2px;
+  border-color: var(--text);
+}
+
+.runtime-loop-heading {
+  color: var(--text-inverse);
+  background: var(--text);
+  border-color: var(--text);
+}
+
+.runtime-loop-heading > span:first-child,
+.runtime-loop-heading small {
+  color: color-mix(in srgb, var(--text-inverse) 60%, transparent);
+}
+
+.loop-badge {
+  margin-left: auto;
+  padding: 5px 8px;
+  color: var(--text-inverse);
+  border: 1px solid color-mix(in srgb, var(--text-inverse) 35%, transparent);
+  border-radius: 999px;
+  font-size: 8px;
+  letter-spacing: 0.05em;
+  text-transform: uppercase;
+}
+
+.runtime-setup {
+  display: grid;
+  grid-template-columns: 1fr 52px 1fr;
+  align-items: stretch;
+  padding: 24px;
+  background: var(--surface-subtle);
+  border-bottom: 1px solid var(--border);
+}
+
+.runtime-setup > div {
+  display: grid;
+  grid-template-columns: minmax(150px, 0.8fr) repeat(3, minmax(110px, 1fr));
+  gap: 12px;
+  align-items: center;
+  min-width: 0;
+  padding: 16px;
+  background: var(--surface);
+  border: 1px solid var(--border-soft);
+}
+
+.runtime-setup > div > span {
+  color: var(--text-muted);
+  font-size: 9px;
+  line-height: 1.35;
+}
+
+.turn-spine {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) 52px minmax(0, 1fr) 52px minmax(0, 1fr);
+  align-items: stretch;
+  padding: 30px 24px;
+}
+
+.flow-card--decision {
+  position: relative;
+  border-color: var(--blue);
+}
+
+.flow-card--decision::after {
+  position: absolute;
+  right: 14px;
+  bottom: -5px;
+  width: 8px;
+  height: 8px;
+  background: var(--surface);
+  border-right: 1px solid var(--blue);
+  border-bottom: 1px solid var(--blue);
+  content: "";
+  transform: rotate(45deg);
+}
+
+.turn-branches {
+  display: grid;
+  grid-template-columns: minmax(290px, 0.8fr) minmax(0, 2.2fr);
+  border-top: 1px solid var(--border);
+}
+
+.terminal-branch,
+.tool-branch {
+  padding: 22px 24px 26px;
+}
+
+.terminal-branch {
+  border-right: 1px solid var(--border);
+}
+
+.branch-label {
+  margin-bottom: 15px;
+  color: var(--text-muted);
+  font-size: 9px;
+  text-transform: uppercase;
+}
+
+.branch-flow {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) 30px minmax(0, 1fr);
+  align-items: stretch;
+}
+
+.branch-flow > div,
+.tool-flow-step {
+  display: flex;
+  min-width: 0;
+  min-height: 90px;
+  flex-direction: column;
+  justify-content: center;
+  padding: 12px;
+  background: var(--surface-subtle);
+  border: 1px solid var(--border-soft);
+}
+
+.branch-flow > div > span,
+.tool-flow-step > span {
+  margin-top: 7px;
+  color: var(--text-muted);
+  font-size: 9px;
+  line-height: 1.4;
+}
+
+.terminal-card {
+  color: var(--text-inverse);
+  background: var(--text) !important;
+  border-color: var(--text) !important;
+}
+
+.terminal-card strong {
+  font-size: 11px;
+  font-weight: 500;
+}
+
+.terminal-card span {
+  color: color-mix(in srgb, var(--text-inverse) 65%, transparent) !important;
+}
+
+.tool-flow {
+  position: relative;
+  display: grid;
+  grid-template-columns: minmax(130px, 0.9fr) 30px minmax(230px, 1.55fr) 30px minmax(150px, 1fr);
+  align-items: stretch;
+  padding-bottom: 22px;
+}
+
+.tool-flow-step--runtime {
+  background: var(--surface);
+  border-color: var(--border);
+}
+
+.tool-flow-step--runtime p {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 4px;
+  margin-top: 11px;
+}
+
+.tool-flow-step--runtime p span {
+  padding: 3px 5px;
+  color: var(--text-muted);
+  background: var(--surface-subtle);
+  border: 1px solid var(--border-soft);
+  border-radius: 2px;
+  font-size: 8px;
+}
+
+.loop-return {
+  position: absolute;
+  right: 0;
+  bottom: 0;
+  color: var(--blue);
+  font-size: 9px;
+}
+
+.runtime-sidepaths {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 12px;
+  margin-top: 20px;
+}
+
+.runtime-sidepaths article {
+  position: relative;
+  display: flex;
+  min-height: 148px;
+  flex-direction: column;
+  padding: 19px;
+  background: color-mix(in srgb, var(--surface) 88%, transparent);
+  border: 1px dashed var(--border);
+}
+
+.runtime-sidepaths article::before {
+  position: absolute;
+  top: -21px;
+  left: 50%;
+  height: 20px;
+  border-left: 1px dashed var(--border);
+  content: "";
+}
+
+.runtime-sidepaths article strong {
+  margin-top: 10px;
+  font-size: 11px;
+  font-weight: 500;
+}
+
+.runtime-sidepaths article > span {
+  margin-top: 9px;
+  color: var(--text-muted);
+  line-height: 1.5;
+}
+
+.runtime-sidepaths article > small {
+  margin-top: auto;
+  padding-top: 12px;
+  color: var(--blue);
+  font-size: 9px;
+}
+
+.runtime-sidepaths-terminal {
+  border-style: solid !important;
+  border-color: var(--negative) !important;
+}
+
+.runtime-sidepaths-terminal > small {
+  color: var(--negative) !important;
+}
+
