+  gap: 8px;
+  align-items: center;
+}
+
+.pierre-tree-heading strong {
+  font-size: 12px;
+}
+
+.pierre-tree-heading span {
+  display: flex;
+  gap: 5px;
+  align-items: center;
+  overflow: hidden;
+  text-overflow: ellipsis;
