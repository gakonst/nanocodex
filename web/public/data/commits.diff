+fn unsupported_tool_message(call: &CodeCall) -> Option<String> {
+    if call.namespace.is_none() && matches!(call.name.as_str(), "exec" | "wait") {
+        return None;
+    }
+    let qualified_name = format!("{}{}", call.namespace.as_deref().unwrap_or(""), call.name);
