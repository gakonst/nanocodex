+
+  .architecture-invariants li > strong {
+    margin-top: 12px;
+  }
+}
+
+@media (max-width: 740px) {
+  .surface-architecture .header-actions {
+    display: none;
+  }
+
+  .surface-architecture .site-header {
+    grid-template-columns: minmax(0, 1fr);
+  }
+
+  .architecture-page {
+    padding-top: 36px;
+    padding-bottom: 72px;
+  }
+
+  .architecture-intro h1 {
+    margin-top: 15px;
+    font-size: 42px;
+  }
+
+  .architecture-intro > p:last-child {
+    margin-top: 20px;
+    font-size: 12px;
+  }
+
+  .api-contract pre {
+    padding: 18px 16px;
+    font-size: 10px;
+  }
+
+  .api-contract dl {
+    grid-template-columns: 1fr;
+  }
+
+  .architecture-section,
+  .architecture-invariants {
+    margin-top: 68px;
+  }
+
+  .architecture-section-heading h2,
+  .architecture-invariants h2 {
+    font-size: 28px;
+  }
+
+  .callgraph {
+    padding: 18px;
+    background-size: 18px 18px;
+  }
+
+  .setup-flow {
+    grid-template-columns: 1fr;
+  }
+
+  .setup-flow li {
+    min-height: 102px;
+  }
+
+  .setup-flow li + li,
+  .setup-flow li:nth-child(3) {
+    border-top: 1px solid var(--border-soft);
+    border-left: 0;
+  }
+
+  .setup-flow li:not(:last-child)::after {
+    top: auto;
+    right: 20px;
+    bottom: -4px;
+    transform: rotate(135deg);
+  }
+
+  .setup-flow li:nth-child(2)::after {
+    display: block;
+  }
+
+  .runtime-loop-heading {
+    align-items: flex-start;
+  }
+
+  .loop-badge {
+    display: none;
+  }
+
+  .runtime-setup,
+  .turn-spine {
+    grid-template-columns: 1fr;
+    padding: 18px;
+  }
+
+  .runtime-setup > .flow-arrow--right,
+  .turn-spine > .flow-arrow--right,
+  .branch-flow > .flow-arrow--right,
+  .tool-flow > .flow-arrow--right {
+    width: 20px;
+    height: 40px;
+    margin-inline: auto;
+  }
+
+  .runtime-setup > .flow-arrow--right::before,
+  .turn-spine > .flow-arrow--right::before,
+  .branch-flow > .flow-arrow--right::before,
+  .tool-flow > .flow-arrow--right::before {
+    top: 0;
+    right: auto;
+    bottom: 6px;
+    left: 50%;
+    width: 1px;
+    height: auto;
+  }
+
+  .runtime-setup > .flow-arrow--right::after,
+  .turn-spine > .flow-arrow--right::after,
+  .branch-flow > .flow-arrow--right::after,
+  .tool-flow > .flow-arrow--right::after {
+    top: auto;
+    right: auto;
+    bottom: 5px;
+    left: 50%;
+    border-top: 0;
+    border-right: 1px solid var(--text);
+    border-bottom: 1px solid var(--text);
+    transform: translateX(-3px) rotate(45deg);
+  }
+
+  .turn-spine {
+    padding-top: 24px;
+    padding-bottom: 24px;
+  }
+
+  .turn-branches {
+    display: block;
+  }
+
+  .terminal-branch,
+  .tool-branch {
+    padding: 18px;
+  }
+
+  .branch-flow,
+  .tool-flow {
+    grid-template-columns: 1fr;
+  }
+
+  .tool-flow {
+    padding-bottom: 28px;
+  }
+
+  .loop-return {
+    right: auto;
+    left: 0;
+  }
+
+  .architecture-invariants {
+    gap: 20px;
+  }
+}
