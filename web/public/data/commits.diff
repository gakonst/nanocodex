+        &mut self,
+        after_model_call_index: u32,
+        started_at: Instant,
+        error: crate::HarnessError,
+    ) -> Result<T> {
+        let duration_ns = elapsed_ns(started_at);
+        self.stats.model_duration_ns += duration_ns;
+        let message = error.to_string();
+        self.events.emit(
+            "model.compaction.failed",
+            CompactionFailed {
+                after_model_call_index,
+                duration_ns,
+                error: &message,
+            },
+        )?;
+        Err(error)
