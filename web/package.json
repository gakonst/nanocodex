{
  "name": "nanocodex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "sync": "node scripts/sync-nanocodex.mjs && node scripts/sync-harbor.mjs",
    "predev": "npm run sync",
    "dev": "vite dev",
    "typecheck": "tsc --noEmit",
    "gen:types": "wrangler types",
    "prebuild": "npm run sync",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy:preview": "npm run build && wrangler deploy --env preview",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@pierre/diffs": "1.2.12",
    "@pierre/trees": "^1.0.0-beta.5",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-switch": "1.2.6",
    "@tanstack/react-virtual": "^3.14.6",
    "lucide-react": "^1.24.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "5.9.3",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  }
}
